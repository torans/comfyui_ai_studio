{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Beikuman ComfyUI",
  "version": "0.1.0",
  "identifier": "com.beikuman.comfyui",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Beikuman ComfyUI Client",
        "width": 1200,
        "height": 850,
        "resizable": true,
        "transparent": false,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": {
          "x": 14,
          "y": 14
        }
      }
    ],
    "macOSPrivateApi": true,
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://admin.test https://admin.test ws://admin.test:8080 http://localhost:8000 ws://localhost:8080 http://127.0.0.1:8000 ws://127.0.0.1:8080 http://comfyui.lanqiu.tech https://comfyui.lanqiu.tech ws://comfyui.lanqiu.tech wss://comfyui.lanqiu.tech; img-src 'self' data: https:; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
